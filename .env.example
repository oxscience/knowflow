# KnowFlow Email Configuration
# Copy this file to .env and fill in your credentials.
#
# Gmail Setup (3 steps):
#   1. Enable 2-Factor Auth: https://myaccount.google.com/security
#   2. Create App Password: https://myaccount.google.com/apppasswords
#      - Select "Mail" as app, give it a name like "KnowFlow"
#   3. Paste the 16-character password below (without spaces)

EMAIL_ADDRESS=your.email@gmail.com
EMAIL_PASSWORD=abcd efgh ijkl mnop

# Optional: override defaults (only needed for non-Gmail providers)
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
